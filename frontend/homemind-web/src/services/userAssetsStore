function normalizeLegacyAsset(asset) {
  const legacyTypeMap = {
    cash: "checking_account",
    investment_fund: "keren_hishtalmut",
    investment: "securities",
  };

  return {
    id:
      asset.id ||
      `asset_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`,
    type: legacyTypeMap[asset.type] || asset.type || "other_asset",
    name: asset.name || "נכס ללא שם",
    description: asset.description || "",
    country: asset.country || "",
    city: asset.city || "",
    estimatedValue: Number(asset.estimatedValue || 0),
    debt: Number(asset.debt || 0),
    monthlyIncome: Number(asset.monthlyIncome || 0),
    currency: asset.currency || "ILS",
    valuationMode: asset.valuationMode || "manual",
    updatedAt: asset.updatedAt || new Date().toISOString(),
  };
}

export function loadUserAssets() {
  const existing = localStorage.getItem(STORAGE_KEY);

  if (existing) {
    try {
      const parsedAssets = JSON.parse(existing);
      const normalizedAssets = parsedAssets.map(normalizeLegacyAsset);

      localStorage.setItem(STORAGE_KEY, JSON.stringify(normalizedAssets));

      return normalizedAssets;
    } catch (error) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(defaultAssets));
      return defaultAssets;
    }
  }

  localStorage.setItem(STORAGE_KEY, JSON.stringify(defaultAssets));

  return defaultAssets;
}

export function saveUserAssets(assets) {
  const normalizedAssets = assets.map(normalizeLegacyAsset);
  localStorage.setItem(STORAGE_KEY, JSON.stringify(normalizedAssets));
}

export function addUserAsset(asset) {
  const assets = loadUserAssets();

  const newAsset = normalizeLegacyAsset({
    ...asset,
    id: `asset_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`,
    updatedAt: new Date().toISOString(),
  });

  const nextAssets = [newAsset, ...assets];

  saveUserAssets(nextAssets);

  return nextAssets;
}

export function updateUserAsset(assetId, updates) {
  const assets = loadUserAssets();

  const nextAssets = assets.map((asset) =>
    asset.id === assetId
      ? normalizeLegacyAsset({
          ...asset,
          ...updates,
          id: asset.id,
          updatedAt: new Date().toISOString(),
        })
      : asset
  );

  saveUserAssets(nextAssets);

  return nextAssets;
}

export function deleteUserAsset(assetId) {
  const assets = loadUserAssets();
  const nextAssets = assets.filter((asset) => asset.id !== assetId);

  saveUserAssets(nextAssets);

  return nextAssets;
}

export function resetUserAssetsToDefault() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(defaultAssets));

  return defaultAssets;
}

export function calculateUserAssetsSummary() {
  const assets = loadUserAssets();

  const totalAssets = assets
    .filter((asset) => asset.type !== "liability")
    .reduce(
      (sum, asset) => sum + Math.max(Number(asset.estimatedValue || 0), 0),
      0
    );

  const assetDebts = assets
    .filter((asset) => asset.type !== "liability")
    .reduce((sum, asset) => sum + Math.max(Number(asset.debt || 0), 0), 0);

  const liabilities = assets
    .filter((asset) => asset.type === "liability")
    .reduce((sum, asset) => {
      const estimatedValue = Math.abs(Number(asset.estimatedValue || 0));
      const debt = Math.abs(Number(asset.debt || 0));

      return sum + Math.max(estimatedValue, debt);
    }, 0);

  const monthlyIncome = assets
    .filter((asset) => asset.type !== "liability")
    .reduce((sum, asset) => sum + Number(asset.monthlyIncome || 0), 0);

  const totalDebt = assetDebts + liabilities;

  return {
    assets,
    totalAssets,
    totalDebt,
    netWorth: totalAssets - totalDebt,
    monthlyIncome,
    assetsCount: assets.length,
  };
}